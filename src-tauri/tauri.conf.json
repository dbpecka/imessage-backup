{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bubble Wrap",
  "version": "0.1.0",
  "identifier": "io.pecka.apps.bubblewrap",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Bubble Wrap",
        "width": 860,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "./entitlements.plist",
      "exceptionDomain": ""
    },
    "category": "Utility",
    "shortDescription": "Backup iMessages and prune chat.db",
    "longDescription": "Export iMessages to HTML, TXT, or JSON; extract attachments; optionally delete old data from chat.db after a successful backup."
  }
}
